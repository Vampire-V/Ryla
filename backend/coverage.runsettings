<?xml version="1.0" encoding="utf-8"?>
<!-- Coverage settings: วัดเฉพาะ Ryla code, exclude source-generated code -->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <!-- วัดเฉพาะ Ryla assemblies — source-generated code จะไม่ถูกนับ -->
          <Include>[Ryla.*]*</Include>
          <ExcludeByAttribute>GeneratedCodeAttribute,CompilerGeneratedAttribute,ExcludeFromCodeCoverageAttribute</ExcludeByAttribute>
          <ExcludeByFile>**/*.g.cs</ExcludeByFile>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
