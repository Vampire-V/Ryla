# ─────────────────────────────────────────────────────────────
# Frontend (Next.js)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─────────────────────────────────────────────────────────────
# MCP Servers (Claude Code integration)
# ดู docs/mcp-servers.md สำหรับวิธีหา values เหล่านี้
# ─────────────────────────────────────────────────────────────

# Supabase MCP — supabase.com → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=your-supabase-personal-access-token
SUPABASE_PROJECT_REF=your-project-ref

# PostgreSQL MCP — direct DB connection
POSTGRES_CONNECTION_STRING=postgresql://postgres:postgres@localhost:54322/postgres

# Azure MCP — portal.azure.com → Subscriptions
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=ryla-prod

# Brave Search MCP — brave.com/search/api
BRAVE_API_KEY=your-brave-api-key

# Context7 MCP — ไม่ต้องการ key
