#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
# Pre-push hook: ป้องกัน push ตรงไป main หรือ develop
# ต้อง push ผ่าน PR เท่านั้น (Gitflow)
#
# ติดตั้ง: git config core.hooksPath .githooks
# ─────────────────────────────────────────────────────────────

PROTECTED_BRANCHES=("main" "develop")
CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

for branch in "${PROTECTED_BRANCHES[@]}"; do
  if [ "$CURRENT_BRANCH" = "$branch" ]; then
    echo ""
    echo "⛔ Push ตรงไป '$branch' ถูกบล็อก!"
    echo ""
    echo "   Ryla ใช้ Gitflow — ต้อง push ผ่าน PR เท่านั้น:"
    echo "   • Feature branches → PR → develop"
    echo "   • release/* branches → PR → main"
    echo ""
    echo "   ถ้าต้องการ bypass (admin only):"
    echo "   git push --no-verify"
    echo ""
    exit 1
  fi
done

exit 0
